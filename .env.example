# === LLM Configuration (Optional) ===
# Pipeline hoat dong duoc ma KHONG can LLM (dung regex + rule-based).
# Bat LLM de nang cao do chinh xac khi extract thong tin phuc tap.

# OpenAI API (neu dung GPT-4o-mini / GPT-4o)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (neu dung local LLM - Recommended cho development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# === Extraction Settings ===
# Bat/tat LLM extraction (true/false)
USE_LLM_EXTRACTION=false

# Ngon ngu CV mac dinh (vi/en)
DEFAULT_LANGUAGE=vi

# === Output Settings ===
# Thu muc luu output JSON (de trong = hien tai)
OUTPUT_DIR=

# Pretty print JSON output (true/false)
JSON_INDENT=2
